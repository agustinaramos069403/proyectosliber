# Copy to .env for local Netlify dev; set the same keys in Netlify → Environment variables.
# Do not commit real tokens — use Netlify UI for production secrets.

# Production wa.me line: +54 9 379 498 3065 (digits only, no +). Do NOT use WHATSAPP_PHONE_NUMBER_ID here.
PUBLIC_WHATSAPP_NUMBER=5493794983065

WHATSAPP_VERIFY_TOKEN=your_secret_verify_token_same_as_meta_webhook_field
WHATSAPP_ACCESS_TOKEN=from_meta_whatsapp_cloud_api
# Meta "Phone number ID" for this test line (Graph API / bot only) — not a dialable number for wa.me.
WHATSAPP_PHONE_NUMBER_ID=1102227742967763

# Optional — WABA ID from Meta (not used by meta-whatsapp-webhook.cjs today).
WHATSAPgfgfP_BUSINESS_ACCOUNT_ID=optional_waba_id_for_your_notes

# Optional: one Calendly (or Google Appointment) URL per sede — bot sends the right link
CALENDLY_CORRIENTES=https://calendly.com/...
CALENDLY_RESISTENCIA=https://calendly.com/...
CALENDLY_SAENZ_PENA=https://calendly.com/...
CALENDLY_FORMOSA=https://calendly.com/...

# Optional — OpenAI Chat Completions for conversational replies when sede is not detected (gpt-4o-mini by default)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# When true (default), OpenAI routes almost every patient message before rule fallbacks.
OPENAI_AI_FIRST_ROUTING=true

# Optional — Google Sheets (private) for obras sociales plus & private prices
# Source of truth spreadsheet (plus tab gid=2110738375):
# https://docs.google.com/spreadsheets/d/1Q3Xtu6d9lRX5APqzcEC4ddvCWB0gonXd/edit?gid=2110738375
# Put the full service account JSON content in GOOGLE_SERVICE_ACCOUNT_JSON (as a single line).
GOOGLE_SERVICE_ACCOUNT_JSON=
# CSV export is a fallback only. When service account + spreadsheet ID are set, the API is used first.
GOOGLE_SHEETS_PLUS_CSV_URL=
GOOGLE_SHEETS_PRIVATE_PRICES_CSV_URL=
# Recommended: point these to the live spreadsheet (not a static copy).
GOOGLE_SHEETS_PLUS_SPREADSHEET_ID=1Q3Xtu6d9lRX5APqzcEC4ddvCWB0gonXd
GOOGLE_SHEETS_PRIVATE_PRICES_SPREADSHEET_ID=
GOOGLE_SHEETS_SPREADSHEET_ID=1Q3Xtu6d9lRX5APqzcEC4ddvCWB0gonXd
# Tab name must match your sheet. If the tab is not "HealthInsurancePlus", set the real name here.
GOOGLE_SHEETS_PLUS_RANGE=HealthInsurancePlus!A:F
GOOGLE_SHEETS_PRIVATE_PRICES_RANGE=PrivatePrices!A:C
# In-memory cache per warm function instance (default 300 seconds).
GOOGLE_SHEETS_CACHE_TTL_SECONDS=300

# Optional — Upstash Redis (free tier) for light conversation memory (stateless serverless-safe)
# If set, the webhook persists short state per WhatsApp number.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Conversation memory (Upstash Redis or in-memory fallback)
# Default inactivity reset: 4 hours without messages before starting fresh.
# CONVERSATION_INACTIVITY_RESET_HOURS=4
# Hard cap on session age even with activity (default 24 hours).
# CONVERSATION_MAX_AGE_HOURS=24
# Redis key TTL in seconds (defaults to inactivity window; max 86400).
CONVERSATION_STATE_TTL_SECONDS=14400
