---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import HeroSection from '../components/HeroSection.astro';
import EmpathySection from '../components/EmpathySection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ValueSection from '../components/ValueSection.astro';
import AvatarsSection from '../components/AvatarsSection.astro';
import AuthoritySection from '../components/AuthoritySection.astro';
import SedesSection from '../components/SedesSection.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import FAQSection from '../components/FAQSection.astro';
import ClosingSection from '../components/ClosingSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import StickyWhatsAppButton from '../components/StickyWhatsAppButton.astro';
import SedeModal from '../components/SedeModal.astro';
---
<BaseLayout
  title="Dr. Liber Acosta | Especialista en Asma, Alergia e Inmunología"
  description="Más de 20 años ayudando a niños y adultos en el NEA a vivir sin síntomas. Consulta médica especializada en asma, alergias e inmunología."
>
  <SiteHeader />
  <main>
    <HeroSection />
    <SedesSection />
    <EmpathySection />
    <ProblemSection />
    <ValueSection />
    <AvatarsSection />
    <AuthoritySection />
    <ReviewsSection />
    <FAQSection />
    <ClosingSection />
  </main>
  <SiteFooter />
  <StickyWhatsAppButton />
  <SedeModal />
</BaseLayout>
