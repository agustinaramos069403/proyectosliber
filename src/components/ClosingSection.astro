---
import WhatsAppButton from './WhatsAppButton.astro';
---
<section id="contacto" class="py-16 md:py-24 bg-brand-clinical/15" aria-labelledby="cierre-heading">
  <div class="container mx-auto max-w-2xl px-4">
    <div class="flex flex-col items-center text-center">
      <h2
        id="cierre-heading"
        class="font-serif text-2xl md:text-3xl text-primary leading-snug mb-8 text-balance"
      >
        Si tenés <strong class="font-bold">síntomas frecuentes</strong> que afectan tu{' '}
        <strong class="font-bold">vida diaria</strong>, es momento de evaluarlo{' '}
        <strong class="font-bold">correctamente.</strong>
      </h2>
      <WhatsAppButton>Agendar ahora por WhatsApp</WhatsAppButton>
    </div>
  </div>
</section>
