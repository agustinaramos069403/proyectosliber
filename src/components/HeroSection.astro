---
import WhatsAppButton from './WhatsAppButton.astro';

const HERO_PATTERN =
  "url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23000000' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\")";
---
<section
  id="hero"
  class="relative flex min-h-[90vh] items-center overflow-hidden"
  aria-labelledby="hero-heading"
>
  <div class="absolute inset-0 bg-background" aria-hidden="true">
    <div
      class="absolute inset-0 opacity-[0.03]"
      style={`background-image: ${HERO_PATTERN}`}
    >
    </div>
  </div>

  <div class="relative z-20 mx-auto w-full max-w-7xl px-6 py-16 lg:px-12">
    <div class="grid items-start gap-12 lg:grid-cols-2">
      <div class="max-w-xl">
        <div class="mb-6 flex flex-wrap gap-2">
          <span
            class="inline-flex items-center rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary"
          >
            Corrientes
          </span>
          <span
            class="inline-flex items-center rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary"
          >
            Resistencia
          </span>
          <span
            class="inline-flex items-center rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary"
          >
            Sáenz Peña
          </span>
          <span
            class="inline-flex items-center rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary"
          >
            Formosa
          </span>
        </div>

        <p class="mb-4 text-sm uppercase tracking-widest text-muted-foreground">
          Precisión científica para tu bienestar diario
        </p>

        <h1
          id="hero-heading"
          class="font-sans text-4xl sm:text-5xl lg:text-6xl font-medium leading-[1.1] text-foreground mb-6 text-balance"
        >
          Recupera tu calidad de vida con{' '}
          <span class="text-accent">Control de Alergia 360°</span>
        </h1>

        <p class="font-serif text-lg text-muted-foreground leading-relaxed mb-8 text-pretty">
          Más de <strong class="font-semibold text-foreground">20 años</strong> tratando pacientes en el{' '}
          <strong class="font-semibold text-foreground">NEA</strong> con diagnóstico preciso y tratamiento innovador para{' '}
          <strong class="font-semibold text-foreground"
            >alergias respiratorias, rinitis, asma y afecciones en la piel.</strong
          >
        </p>

        <div class="flex flex-col gap-4 sm:flex-row">
          <WhatsAppButton>Quiero agendar mi consulta</WhatsAppButton>
        </div>
      </div>

      <div class="order-last flex flex-col items-center lg:order-last">
        <div class="relative">
          <div class="absolute -inset-4 rounded-full bg-primary/5" aria-hidden="true"></div>
          <div
            class="relative h-[350px] w-[280px] overflow-hidden rounded-3xl bg-secondary sm:h-[400px] sm:w-[320px] lg:h-[500px] lg:w-[400px]"
          >
            <img
              src="/images/dr-liber-acosta.jpg"
              alt="Dr. Liber Acosta - Especialista en Asma, Alergia e Inmunología"
              class="h-full w-full object-cover object-top"
              width="800"
              height="1000"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
          <div
            class="absolute bottom-8 -right-4 z-10 max-w-[13rem] rounded-2xl bg-brand-authority px-4 py-3 text-white shadow-lg sm:-right-6 sm:max-w-[14rem] sm:px-5 lg:-right-8"
          >
            <p class="font-sans text-lg font-semibold leading-snug sm:text-xl">Dr. Liber Acosta</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
