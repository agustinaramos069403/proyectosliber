---
import { getWhatsAppUrl, SEDES } from '../config';
---
<div
  id="sede-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/50 p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="sede-modal-title"
>
  <div
    class="relative w-full max-w-md rounded-2xl bg-white p-6 shadow-2xl"
    onclick="event.stopPropagation()"
  >
    <button
      type="button"
      id="sede-modal-close"
      class="absolute right-4 top-4 text-brand-technical/40 hover:text-brand-authority"
      aria-label="Cerrar"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <h3 id="sede-modal-title" class="font-sans text-xl font-semibold text-brand-authority mb-2">
      ¿A qué sede querés asistir?
    </h3>
    <p class="text-brand-technical/85 mb-6">
      Elegí una de las cuatro sedes. Se abrirá WhatsApp con un mensaje listo para enviar sobre el Sistema 360 y la sede que elijas.
    </p>
    <div class="space-y-3">
      {SEDES.map((sede) => (
        <a
          href={getWhatsAppUrl(sede)}
          target="_blank"
          rel="noopener noreferrer"
          class="sede-option flex items-center justify-between w-full px-4 py-3 rounded-xl border border-brand-authority/15 hover:border-brand-authority hover:bg-brand-breath transition-colors text-left font-medium text-brand-technical"
          data-sede={sede}
        >
          {sede}
          <svg class="w-5 h-5 text-brand-immune" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    if (document.documentElement.dataset.sedeModalScript === '1') return;
    document.documentElement.dataset.sedeModalScript = '1';

    var modal = document.getElementById('sede-modal');
    var closeBtn = document.getElementById('sede-modal-close');
    if (!modal) return;

    function closeMobileHeaderMenuIfOpen() {
      var mobileNav = document.getElementById('site-header-mobile-nav');
      if (!mobileNav || mobileNav.classList.contains('hidden')) return;
      var menuButton = document.querySelector('.site-header__menu-button');
      var iconOpen = document.querySelector('.site-header__icon-open');
      var iconClose = document.querySelector('.site-header__icon-close');
      mobileNav.classList.add('hidden');
      if (iconOpen) iconOpen.classList.remove('hidden');
      if (iconClose) iconClose.classList.add('hidden');
      if (menuButton) {
        menuButton.setAttribute('aria-expanded', 'false');
        menuButton.setAttribute('aria-label', 'Abrir menú');
      }
    }

    function openModal() {
      closeMobileHeaderMenuIfOpen();
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    document.addEventListener(
      'click',
      function (event) {
        var target = event.target;
        if (!(target instanceof Element)) return;
        var trigger = target.closest('[data-open-sede-modal]');
        if (!trigger) return;
        event.preventDefault();
        openModal();
      },
      false
    );

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function (event) {
      if (event.target === modal) closeModal();
    });
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') closeModal();
    });
  })();
</script>
