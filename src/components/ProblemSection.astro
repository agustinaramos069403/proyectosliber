---
const PROBLEMS = [
  {
    title: 'Automedicación',
    description: 'Alivio pasajero que oculta el problema real.',
    icon: 'pill',
  },
  {
    title: 'Impacto Familiar',
    description: 'Noches sin dormir o niños que no pueden jugar por el asma o alergia.',
    icon: 'moon',
  },
  {
    title: 'El Laberinto Médico',
    description:
      'Ir de especialista en especialista sin una respuesta clara ni un tratamiento que resuelva el problema.',
    icon: 'compass',
  },
];
---
<section class="py-20 lg:py-28 bg-background" aria-labelledby="problems-heading">
  <div class="container mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2
        id="problems-heading"
        class="font-sans text-3xl sm:text-4xl lg:text-5xl font-medium text-foreground mb-4 text-balance"
      >
        Lo que muchos pacientes viven durante años
      </h2>
    </div>

    <div class="mb-16 grid gap-8 md:grid-cols-3">
      {PROBLEMS.map((problem) => (
        <div class="relative group">
          <div class="h-full rounded-2xl border border-border bg-card p-8 shadow-sm transition-shadow hover:shadow-md">
            <div
              class="mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-brand-clinical"
              aria-hidden="true"
            >
              {problem.icon === 'pill' && (
                <svg class="h-7 w-7 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10.5 13.5 6 18a3.5 3.5 0 0 1-5-5l4.5-4.5M13.5 10.5 18 6a3.5 3.5 0 0 1 5 5l-4.5 4.5M8.5 8.5 15.5 15.5"
                  />
                </svg>
              )}
              {problem.icon === 'moon' && (
                <svg class="h-7 w-7 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                  />
                </svg>
              )}
              {problem.icon === 'compass' && (
                <svg class="h-7 w-7 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.24 7.76-2.12 6.36-6.36 2.12 2.12-6.36 6.36-2.12z" />
                </svg>
              )}
            </div>
            <h3 class="font-sans text-xl font-semibold text-foreground mb-3">{problem.title}</h3>
            <p class="font-serif text-muted-foreground leading-relaxed">{problem.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="rounded-2xl bg-brand-authority p-8 text-center md:p-12">
      <p class="font-sans text-xl md:text-2xl lg:text-3xl font-medium text-white mb-2 text-balance">
        El problema no es el síntoma.
      </p>
      <p class="font-serif text-lg md:text-xl text-brand-clinical">El problema es no conocer la causa.</p>
    </div>
  </div>
</section>
