---
const SYMPTOMS = [
  'Congestión nasal constante',
  'Estornudos repetidos',
  'Picazón en nariz, ojos o piel',
  'Tos, silbidos en el pecho o falta de aire',
  'Dermatitis, urticaria o brotes en la piel',
  'Cansancio o mal descanso por los síntomas',
  'Síntomas que aparecen y desaparecen sin explicación',
  'Dependencia de medicación sin mejoría real',
];
---
<section
  id="sintomas"
  class="py-20 lg:py-28 bg-brand-authority"
  aria-labelledby="symptoms-heading"
>
  <div class="container mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h2
        id="symptoms-heading"
        class="font-sans text-3xl sm:text-4xl lg:text-5xl font-medium text-white mb-4 text-balance"
      >
        ¿Te pasa algo de esto con frecuencia?
      </h2>
    </div>

    <div class="mb-12 grid gap-4 sm:grid-cols-2">
      {SYMPTOMS.map((symptom) => (
        <div
          class="flex items-center gap-4 rounded-xl border border-white/20 bg-white/10 p-5 backdrop-blur-sm transition-all hover:bg-white/15"
        >
          <div class="shrink-0">
            <svg
              class="h-6 w-6 text-brand-immune"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span class="font-serif text-lg text-white/90">{symptom}</span>
        </div>
      ))}
    </div>

    <div class="text-center">
      <p
        class="font-serif text-2xl md:text-3xl text-white leading-relaxed max-w-2xl mx-auto font-medium"
      >
        Podría tratarse de una alergia <span class="text-brand-immune">mal diagnosticada</span> o{' '}
        <span class="text-brand-immune">mal tratada.</span>
      </p>
    </div>
  </div>
</section>
