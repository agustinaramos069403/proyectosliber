---
const AUDIENCE_CARDS = [
  {
    title: 'Tu hijo vive con síntomas respiratorios o alergias',
    description: 'Tos persistente, mocos constantes, crisis asmáticas o dificultad para dormir y jugar con normalidad.',
    mediaKey: 'child',
    accentClass: 'from-rose-500/14 via-rose-500/0 to-transparent',
  },
  {
    title: 'Convivís con alergia o tenés diagnóstico de asma',
    description: 'Congestión, estornudos, falta de aire, silbidos en el pecho o cansancio que afecta tu trabajo, estudio o descanso.',
    mediaKey: 'adult',
    accentClass: 'from-sky-500/14 via-sky-500/0 to-transparent',
  },
  {
    title: 'Ya probaste distintos tratamientos y el problema sigue',
    description: 'Pasaste por especialistas o medicación, pero los síntomas vuelven o no terminan de resolverse.',
    mediaKey: 'loop',
    accentClass: 'from-indigo-500/14 via-indigo-500/0 to-transparent',
  },
];
---
<section class="py-16 lg:py-24 bg-brand-breath">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl font-semibold text-brand-authority text-center mb-12">
      Este enfoque es para vos si:
    </h2>
    <div class="grid md:grid-cols-3 gap-8">
      {AUDIENCE_CARDS.map((AudienceCard) => (
        <div class="group overflow-hidden rounded-2xl bg-white shadow-md border border-brand-authority/10 hover:border-brand-authority/25 transition-shadow">
          <div class="relative h-44 sm:h-48">
            {AudienceCard.mediaKey === 'child' && (
              <img
                src="/audience-child.png"
                alt=""
                class="absolute inset-0 h-full w-full object-cover object-[50%_35%]"
                loading="lazy"
                decoding="async"
              />
            )}
            {AudienceCard.mediaKey === 'adult' && (
              <img
                src="/audience-adult.png"
                alt=""
                class="absolute inset-0 h-full w-full object-cover object-[50%_35%]"
                loading="lazy"
                decoding="async"
              />
            )}
            {AudienceCard.mediaKey === 'loop' && (
              <img
                src="/audience-treatment.png"
                alt=""
                class="absolute inset-0 h-full w-full object-cover object-[50%_55%]"
                loading="lazy"
                decoding="async"
              />
            )}
            <div class={`absolute inset-0 bg-gradient-to-br ${AudienceCard.accentClass}`} aria-hidden="true"></div>
            <div class="absolute inset-0 opacity-[0.07] bg-[radial-gradient(circle_at_10%_20%,rgba(0,51,85,1),transparent_55%),radial-gradient(circle_at_90%_10%,rgba(42,59,71,1),transparent_40%)]" aria-hidden="true"></div>
            <div class="relative flex h-full items-end p-5">
              {!['child', 'adult', 'loop'].includes(AudienceCard.mediaKey) && (
                <div class="grid h-12 w-12 place-items-center rounded-2xl bg-white/80 ring-1 ring-brand-authority/10 backdrop-blur">
                {AudienceCard.mediaKey === 'child' && (
                  <svg
                    aria-hidden="true"
                    viewBox="0 0 24 24"
                    class="h-6 w-6 text-rose-700"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 12a4 4 0 1 0-4-4" />
                    <path d="M8 12a6 6 0 0 0-6 6v2h10" />
                    <path d="M16 10a3 3 0 1 0-3-3" />
                    <path d="M22 20v-2a5 5 0 0 0-5-5" />
                  </svg>
                )}
                {AudienceCard.mediaKey === 'adult' && (
                  <svg
                    aria-hidden="true"
                    viewBox="0 0 24 24"
                    class="h-6 w-6 text-sky-700"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 12a4 4 0 1 0-4-4" />
                    <path d="M4 22v-2a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v2" />
                    <path d="M8 9h8" />
                  </svg>
                )}
                {AudienceCard.mediaKey === 'loop' && (
                  <svg
                    aria-hidden="true"
                    viewBox="0 0 24 24"
                    class="h-6 w-6 text-indigo-700"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M3 12a9 9 0 0 1 15-6l2-2v6h-6l2-2A7 7 0 0 0 5 12" />
                    <path d="M21 12a9 9 0 0 1-15 6l-2 2v-6h6l-2 2a7 7 0 0 0 11-4" />
                  </svg>
                )}
                </div>
              )}
            </div>
          </div>

          <div class="p-7">
            <h3 class="font-display font-semibold text-xl text-brand-authority mb-3">
              {AudienceCard.title}
            </h3>
            <p class="text-brand-technical/85 leading-relaxed text-lg">{AudienceCard.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
