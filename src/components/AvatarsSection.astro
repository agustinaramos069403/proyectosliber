---
const AUDIENCES = [
  {
    image: '/images/child-allergy.jpg',
    title: 'Tu hijo vive con síntomas respiratorios o alergias',
    description:
      'Tos persistente, mocos constantes, crisis asmáticas o dificultad para dormir y jugar con normalidad.',
    accentClass: 'bg-brand-immune',
  },
  {
    image: '/images/asma-alergia.jpg',
    title: 'Convivís con alergia o tenés diagnóstico de asma',
    description:
      'Congestión, estornudos, falta de aire, silbidos en el pecho o cansancio que afecta tu trabajo, estudio o descanso.',
    accentClass: 'bg-brand-clinical',
  },
  {
    image: '/images/multiple-treatments.jpg',
    title: 'Ya probaste distintos tratamientos y el problema sigue',
    description: 'Pasaste por especialistas o medicación, pero los síntomas vuelven o no terminan de resolverse.',
    accentClass: 'bg-brand-authority',
  },
];
---
<section class="py-12 sm:py-16 lg:py-28 bg-background" aria-labelledby="target-audience-heading">
  <div class="container mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2
        id="target-audience-heading"
        class="font-sans text-3xl sm:text-4xl lg:text-5xl font-medium text-foreground text-balance"
      >
        Este enfoque es para vos si:
      </h2>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {AUDIENCES.map((audience) => (
        <article class="group overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all duration-300 hover:border-brand-clinical/30 hover:shadow-xl">
          <div class="relative h-56 overflow-hidden">
            <img
              src={audience.image}
              alt={audience.title}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              width="640"
              height="360"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-authority/20 to-transparent" aria-hidden="true">
            </div>
            <div class={`absolute bottom-0 left-0 right-0 h-1 ${audience.accentClass}`} aria-hidden="true"></div>
          </div>
          <div class="p-6">
            <h3 class="font-sans text-lg font-semibold text-foreground mb-3 leading-snug">{audience.title}</h3>
            <p class="font-serif text-sm text-muted-foreground leading-relaxed">{audience.description}</p>
          </div>
          <div class="px-6 pb-6">
            <div
              class="flex items-center gap-2 text-brand-immune opacity-0 transition-opacity duration-300 group-hover:opacity-100"
            >
              <span class="font-serif text-sm font-medium">Podemos ayudarte</span>
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-8 sm:mt-10 lg:mt-12 text-center">
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 rounded-full bg-brand-authority px-8 py-4 font-sans font-medium text-white transition-colors hover:bg-brand-authority/90"
      >
        Quiero una consulta
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
