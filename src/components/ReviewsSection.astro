---
// Reemplazá con reseñas reales de Google My Business. Formato: { text, author, rating }
import { GOOGLE_REVIEWS_URL } from '../config';
const reviews = [
  {
    text: 'Excelente atención. Por fin encontré un diagnóstico claro después de años de síntomas.',
    author: 'Paciente de Corrientes',
    rating: 5,
  },
  {
    text: 'Mi hijo dejó de tener crisis de asma. El Dr. Liber cambió nuestra vida.',
    author: 'Madre de paciente pediátrico',
    rating: 5,
  },
  {
    text: 'Profesional, empático y con un enfoque integral. Muy recomendable.',
    author: 'Paciente de Resistencia',
    rating: 5,
  },
];
---
<section class="relative py-16 lg:py-24 overflow-hidden bg-gradient-to-b from-brand-breath via-white to-brand-breath">
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.8] bg-[radial-gradient(circle_at_10%_15%,rgba(79,183,167,0.18),transparent_55%),radial-gradient(circle_at_90%_25%,rgba(139,214,203,0.16),transparent_55%),radial-gradient(circle_at_45%_90%,rgba(11,63,60,0.10),transparent_62%)]"
    aria-hidden="true"
  ></div>

  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <img
      src="/audience-child.png"
      alt=""
      class="absolute -top-24 left-1/2 h-[520px] w-[820px] -translate-x-1/2 rotate-3 object-cover opacity-[0.10] blur-2xl saturate-110 contrast-105"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-white/40 via-transparent to-brand-breath/70"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="mx-auto max-w-3xl text-center mb-12 lg:mb-16">
      <span class="inline-flex items-center gap-2 px-5 py-2 text-sm sm:text-base font-medium text-brand-authority bg-white/80 rounded-full shadow-sm ring-1 ring-brand-authority/10">
        Testimonios
      </span>
      <h2 class="font-display mt-3 text-2xl sm:text-3xl lg:text-4xl font-semibold text-brand-authority tracking-tight">
        Lo que dicen mis pacientes sobre mí
      </h2>
      <p class="mt-3 text-base sm:text-lg text-brand-technical/80">
        Historias reales de personas que recuperaron tranquilidad y control de sus síntomas.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3 md:gap-7 mb-12 lg:mb-14">
      {reviews.map((review) => (
        <article class="group relative overflow-hidden rounded-3xl bg-white/85 ring-1 ring-brand-authority/10 shadow-md backdrop-blur transition-transform duration-200 hover:-translate-y-[2px] hover:shadow-line">
          <div
            class="pointer-events-none absolute inset-0 opacity-[0.75] bg-[radial-gradient(circle_at_18%_15%,rgba(79,183,167,0.10),transparent_55%),radial-gradient(circle_at_92%_30%,rgba(139,214,203,0.10),transparent_52%)]"
            aria-hidden="true"
          ></div>
          <div
            class="pointer-events-none absolute inset-x-0 top-0 h-[5px] bg-gradient-to-r from-brand-immune/35 via-brand-clinical/35 to-transparent"
            aria-hidden="true"
          ></div>
          <div class="relative p-6 sm:p-7">
            <div class="flex items-start justify-between gap-4 mb-4">
              <div class="inline-flex items-center gap-1 rounded-full bg-brand-breath/80 px-3 py-1 ring-1 ring-brand-authority/10">
                {Array.from({ length: review.rating }).map(() => (
                  <span class="text-brand-clinical/95 drop-shadow-[0_1px_0_rgba(255,255,255,0.9)]">★</span>
                ))}
              </div>
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                class="h-7 w-7 text-brand-authority/16"
                fill="currentColor"
              >
                <path d="M7.3 17.4c-1.5 0-2.8-.5-3.8-1.5S2 13.6 2 12.1c0-1 .2-2 .7-3s1.2-2 2.2-2.9c1-.9 2.2-1.6 3.6-2.1l1 1.9c-1.2.6-2.2 1.3-3 2.1-.8.8-1.3 1.6-1.5 2.5.4-.2.9-.3 1.5-.3 1.1 0 2 .4 2.7 1.1.7.7 1.1 1.6 1.1 2.7 0 1.2-.4 2.2-1.2 3-.8.8-1.8 1.2-3 1.2Zm12.7 0c-1.5 0-2.8-.5-3.8-1.5s-1.5-2.3-1.5-3.8c0-1 .2-2 .7-3s1.2-2 2.2-2.9c1-.9 2.2-1.6 3.6-2.1l1 1.9c-1.2.6-2.2 1.3-3 2.1-.8.8-1.3 1.6-1.5 2.5.4-.2.9-.3 1.5-.3 1.1 0 2 .4 2.7 1.1.7.7 1.1 1.6 1.1 2.7 0 1.2-.4 2.2-1.2 3-.8.8-1.8 1.2-3 1.2Z" />
              </svg>
            </div>

            <p class="text-brand-technical/90 italic mb-5 text-base sm:text-lg leading-relaxed">
              “{review.text}”
            </p>

            <div class="mt-auto flex items-center gap-3 pt-4 border-t border-brand-authority/10">
              <div class="grid h-9 w-9 place-items-center rounded-full bg-brand-breath ring-1 ring-brand-authority/10 text-brand-authority/70 text-sm font-semibold">
                {review.author.slice(0, 1)}
              </div>
              <p class="text-sm sm:text-base text-brand-technical/70">
                <span class="font-medium text-brand-technical/80">{review.author}</span>
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
    <div class="text-center">
      <a
        href={GOOGLE_REVIEWS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/80 ring-1 ring-brand-authority/10 shadow-sm text-brand-authority font-medium hover:text-brand-immune hover:shadow-line transition-shadow"
      >
        Ver más reseñas en Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>
