---
const LOCATIONS = [
  { city: 'Corrientes', place: 'Clínica del Pilar' },
  { city: 'Resistencia', place: 'IMMI' },
  { city: 'Sáenz Peña', place: 'Clínica Santa María' },
  { city: 'Formosa', place: 'Instituto de Gastroenterología' },
];
---
<section id="sedes" class="py-10 lg:py-12 bg-brand-breath" aria-labelledby="sedes-heading">
  <div class="max-w-6xl mx-auto px-6">
    <h2 id="sedes-heading" class="font-display text-lg sm:text-xl font-semibold text-brand-authority text-center mb-6">
      Consultorios
    </h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      {LOCATIONS.map((Location) => (
        <div class="p-3 sm:p-4 rounded-xl bg-white border border-brand-authority/10 text-center">
          <p class="inline-flex items-center justify-center gap-2 font-semibold text-brand-authority text-sm sm:text-base">
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              class="h-4 w-4 text-brand-authority/80"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11Z" />
              <circle cx="12" cy="10" r="2.5" />
            </svg>
            <span>{Location.city}</span>
          </p>
          <p class="text-sm text-brand-technical/80">{Location.place}</p>
        </div>
      ))}
    </div>
  </div>
</section>
