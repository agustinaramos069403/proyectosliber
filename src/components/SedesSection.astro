---
const LOCATIONS = [
  { city: 'Corrientes', clinic: 'Clínica del Pilar' },
  { city: 'Resistencia', clinic: 'Instituto Modelo de Medicina Infantil' },
  { city: 'Sáenz Peña', clinic: 'Clínica Santa María' },
  { city: 'Formosa', clinic: 'Instituto de Gastroenterología' },
];
---
<section id="consultorios" class="py-20 bg-background" aria-labelledby="sedes-heading">
  <div class="container mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-6 flex justify-center">
      <span
        class="inline-flex items-center rounded-full border border-border bg-card px-4 py-1.5 font-serif text-sm text-foreground"
      >
        Consultorios
      </span>
    </div>

    <div class="mx-auto mb-12 max-w-2xl text-center">
      <h2 id="sedes-heading" class="font-sans text-3xl sm:text-4xl font-medium text-foreground mb-4 text-balance">
        Elegí tu sede más cercana
      </h2>
      <p class="font-serif text-lg text-muted-foreground">
        Coordiná tu consulta en la ciudad que te quede mejor.
      </p>
    </div>

    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {LOCATIONS.map((location) => (
        <div
          class="group flex cursor-pointer items-center gap-4 rounded-2xl border border-border bg-card p-5 transition-all duration-200 hover:border-accent/50 hover:shadow-md"
        >
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent/10">
            <svg
              class="h-5 w-5 text-accent"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-sans font-semibold text-foreground transition-colors group-hover:text-primary">
              {location.city}
            </h3>
            <div class="font-serif text-sm text-muted-foreground">
              <p class="leading-snug">{location.clinic}</p>
              {'clinicDetail' in location && location.clinicDetail ? (
                <p class="mt-0.5 leading-snug text-muted-foreground/90">{location.clinicDetail}</p>
              ) : null}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
