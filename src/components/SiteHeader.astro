  role="banner"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-2.5 sm:py-3 flex items-center justify-between gap-3">
    <a
      href="#top"
      class="flex items-center gap-2.5 sm:gap-3 min-w-0 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-authority focus-visible:ring-offset-2 focus-visible:ring-offset-white"
    >
      <img
        src="/brand-logo.png"
        alt=""
        class="h-9 w-9 sm:h-10 sm:w-10 rounded-lg object-contain shrink-0 ring-1 ring-brand-authority/20"
        width="40"
        height="40"
        fetchpriority="high"
      />
      <div class="min-w-0 text-left">
        <span class="font-display font-semibold text-brand-authority text-sm sm:text-base tracking-tight block leading-snug truncate">
          Dr. Liber Acosta
        </span>
        <span class="text-brand-technical/80 text-xs sm:text-sm font-normal leading-snug truncate block sm:max-w-[min(100%,24rem)]">
          Asma · Alergia · Inmunología
        </span>
