---
---
<header
  class="site-header fixed inset-x-0 top-0 z-50"
  role="banner"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-2.5 sm:py-3 flex items-center justify-between gap-3">
    <a
      href="#top"
      class="flex items-center gap-2.5 sm:gap-3 min-w-0 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-authority focus-visible:ring-offset-2 focus-visible:ring-offset-white"
    >
      <img
        src="/brand-logo.png"
        alt=""
        class="site-header__logo h-9 w-9 sm:h-10 sm:w-10 rounded-lg object-contain shrink-0 ring-1 ring-brand-authority/20"
        width="40"
        height="40"
        fetchpriority="high"
      />
      <div class="min-w-0 text-left">
        <span class="site-header__title font-display font-semibold text-brand-authority text-sm sm:text-base tracking-tight block leading-snug truncate">
          Dr. Liber Acosta
        </span>
        <span class="site-header__subtitle text-brand-technical/80 text-xs sm:text-sm font-normal leading-snug truncate block sm:max-w-[min(100%,24rem)]">
          Asma · Alergia · Inmunología
        </span>
      </div>
    </a>
  </div>
</header>

<script>
  const HEADER_SCROLLED_CLASS = 'site-header--scrolled';
  const HeaderElement = document.querySelector('.site-header');

  const UpdateHeaderState = () => {
    if (!HeaderElement) return;
    HeaderElement.classList.toggle(HEADER_SCROLLED_CLASS, window.scrollY > 8);
  };

  UpdateHeaderState();
  window.addEventListener('scroll', UpdateHeaderState, { passive: true });
</script>
