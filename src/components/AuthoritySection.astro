---
const CREDENTIALS = [
  {
    text: 'Formación en Medicina Interna (Hospital Naval Buenos Aires)',
    icon: 'graduation',
  },
  {
    text: 'Especialización avalada por la Asociación Médica Argentina (AMA)',
    icon: 'award',
  },
  {
    text: 'Experiencia internacional: Hospital Clínico San Carlos (Madrid)',
    icon: 'globe',
  },
];
---
<section id="sobre-mi" class="py-12 sm:py-16 lg:py-24 bg-background">
  <div class="mx-auto max-w-7xl px-6 lg:px-12">
    <div class="grid gap-16 items-center lg:grid-cols-2">
      <div class="relative">
        <div class="aspect-[4/5] overflow-hidden rounded-3xl bg-secondary shadow-xl">
          <img
            src="/images/dr-liber-final.jpg"
            alt="Dr. Liber Acosta en su consultorio"
            class="h-full w-full object-cover object-top"
            width="800"
            height="1000"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="absolute -bottom-6 -right-6 -z-10 h-48 w-48 rounded-2xl bg-brand-immune/10" aria-hidden="true">
        </div>
        <div class="absolute -left-4 -top-4 -z-10 h-24 w-24 rounded-full bg-brand-clinical/20" aria-hidden="true">
        </div>
        <div
          class="absolute bottom-8 -right-4 rounded-2xl bg-brand-authority px-6 py-4 text-white shadow-lg lg:-right-8"
        >
          <p class="font-sans text-3xl font-bold">+20</p>
          <p class="font-serif text-sm text-brand-clinical">años de trayectoria</p>
        </div>
      </div>

      <div>
        <p
          class="mb-6 inline-block rounded-full bg-brand-immune/10 px-4 py-2 text-sm font-medium tracking-wide text-brand-immune"
        >
          Sobre el Doctor
        </p>
        <h2 class="font-sans text-3xl sm:text-4xl lg:text-5xl font-medium text-brand-authority mb-2 text-balance">
          Dr. Liber Acosta
        </h2>
        <p class="font-sans text-xl font-medium text-brand-immune mb-3">Especialista en Asma, Alergia e Inmunología</p>
        <p class="font-serif text-lg text-muted-foreground mb-4">Especialista en Clínica Médica (UBA)</p>
        <p class="font-serif text-lg leading-relaxed text-brand-technical mb-10">
          +20 años de trayectoria en el sector privado del NEA
        </p>

        <div class="space-y-4">
          {CREDENTIALS.map((credential) => (
            <div
              class="flex items-start gap-4 rounded-xl border border-border bg-white p-4 transition-all duration-300 hover:border-brand-clinical hover:shadow-md"
            >
              <div
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-authority/10"
                aria-hidden="true"
              >
                {credential.icon === 'graduation' && (
                  <svg class="h-5 w-5 text-brand-authority" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M22 10v6M2 10l10-5 10 5-10 5zM6 12v5c3 3 9 3 12 0v-5"
                    />
                  </svg>
                )}
                {credential.icon === 'award' && (
                  <svg class="h-5 w-5 text-brand-authority" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <circle cx="12" cy="8" r="6" stroke-width="2" />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"
                    />
                  </svg>
                )}
                {credential.icon === 'globe' && (
                  <svg class="h-5 w-5 text-brand-authority" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" stroke-width="2" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20" />
                  </svg>
                )}
              </div>
              <p class="font-serif leading-relaxed text-brand-technical pt-2">{credential.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
